@page "/ui/redirects"
@model number_sequence.Pages.UI.Redirects.IndexModel
@{
  ViewData["Title"] = "My Redirects";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <h2 class="mb-0">My Redirects</h2>
  <a href="/ui/redirects/create" class="btn btn-sm btn-primary">Create</a>
</div>

@if (Model.Redirects.Count == 0)
{
  <p class="text-muted">No redirects yet.</p>
}
else
{
  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>ID</th>
        <th>Target</th>
        <th class="text-nowrap text-end">Hits</th>
        <th class="text-nowrap">Created</th>
        <th class="text-nowrap">Expires</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var r in Model.Redirects)
      {
        var expired = r.Expiration.HasValue && r.Expiration < DateTimeOffset.UtcNow;
        <tr>
          <td><a href="/r/@r.Id">@r.Id</a></td>
          <td class="text-truncate" style="max-width:20rem" title="@r.Value">@r.Value</td>
          <td class="text-nowrap text-end">@r.Hits</td>
          <td class="text-nowrap">@r.CreatedDate.ToString("yyyy-MM-dd")</td>
          <td class="text-nowrap">
            @if (r.Expiration.HasValue)
            {
              @r.Expiration.Value.ToString("yyyy-MM-dd")
              if (expired)
              {
                <span class="badge bg-danger ms-1">Expired</span>
              }
            }
          </td>
        </tr>
      }
    </tbody>
  </table>
}
