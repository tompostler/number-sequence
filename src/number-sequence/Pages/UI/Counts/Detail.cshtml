@page "/ui/counts/{name}"
@model number_sequence.Pages.UI.Counts.DetailModel
@{
  ViewData["Title"] = Model.Count?.Name ?? "Count";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <h2 class="mb-0">@Model.Count.Name</h2>
  <a href="/ui/counts" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
  <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3 mb-4">
  <div class="col-auto">
    <div class="card text-center" style="min-width:10rem">
      <div class="card-body">
        <div class="display-5 fw-bold">@Model.Count.Value</div>
        <div class="text-muted small">current value</div>
      </div>
    </div>
  </div>
  <div class="col-auto d-flex flex-column gap-2 justify-content-center">
    <form method="post" asp-page-handler="Increment">
      <button type="submit" class="btn btn-primary">+1</button>
    </form>
    <form method="post" asp-page-handler="IncrementBy" class="d-flex gap-2 align-items-center">
      <input asp-for="IncrementAmount" type="number" class="form-control form-control-sm" style="width:7rem" min="1" />
      <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">+ amount</button>
    </form>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-auto">
    <dl class="mb-0">
      <dt class="text-muted small">Created</dt>
      <dd>@Model.Count.CreatedDate.ToString("yyyy-MM-dd HH:mm") UTC</dd>
      <dt class="text-muted small">Modified</dt>
      <dd class="mb-0">@Model.Count.ModifiedDate.ToString("yyyy-MM-dd HH:mm") UTC</dd>
    </dl>
  </div>
  <div class="col-auto">
    <dt class="text-muted small mb-1">Overflow drops oldest events</dt>
    @if (Model.Count.OverflowDropsOldestEvents)
    {
      <div class="d-flex align-items-center gap-2">
        <span>Yes</span>
        <form method="post" asp-page-handler="SetOverflow">
          <input type="hidden" name="overflow" value="false" />
          <button type="submit" class="btn btn-sm btn-outline-secondary">Disable</button>
        </form>
      </div>
    }
    else
    {
      <div class="d-flex align-items-center gap-2">
        <span>No</span>
        <form method="post" asp-page-handler="SetOverflow">
          <input type="hidden" name="overflow" value="true" />
          <button type="submit" class="btn btn-sm btn-outline-secondary">Enable</button>
        </form>
      </div>
    }
  </div>
</div>

@if (Model.Events is { Count: > 0 })
{
  <div class="mb-4">
    <img src="/ui/counts/@Model.Count.Name/chart" class="img-fluid" alt="Count chart" />
  </div>

  <h5>Event history (@Model.Events.Count)</h5>
  <table class="table table-striped table-sm w-auto">
    <thead>
      <tr>
        <th class="text-nowrap">ID</th>
        <th class="text-nowrap">Value</th>
        <th class="text-nowrap">+Amount</th>
        <th class="text-nowrap">Date (UTC)</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var e in Model.Events.OrderByDescending(x => x.Id))
      {
        <tr>
          <td class="text-muted small">@e.Id</td>
          <td>@e.Value</td>
          <td class="text-muted">+@e.IncrementAmount</td>
          <td class="text-nowrap">@e.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
        </tr>
      }
    </tbody>
  </table>
}
else
{
  <p class="text-muted">No events yet.</p>
}
