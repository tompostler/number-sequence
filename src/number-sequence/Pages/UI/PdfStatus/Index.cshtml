@page "/ui/pdf-status"
@model number_sequence.Pages.UI.PdfStatus.IndexModel
@{
  ViewData["Title"] = "PDF Status";
}

<script>
  if (!new URLSearchParams(window.location.search).has('HoursOffset')) {
    var offset = -new Date().getTimezoneOffset() / 60;
    var url = new URL(window.location);
    url.searchParams.set('HoursOffset', offset);
    window.location.replace(url);
  }
</script>

<div class="d-flex align-items-center gap-3 mb-4">
  <h2 class="mb-0">PDF Status</h2>
  <form method="get" class="d-flex align-items-center gap-2">
    <label for="HoursOffset" class="form-label mb-0">UTC offset</label>
    <input id="HoursOffset" name="HoursOffset" type="number" step="0.5" value="@Model.HoursOffset" class="form-control form-control-sm" style="width:6rem" />
    <button type="submit" class="btn btn-sm btn-outline-secondary">Apply</button>
  </form>
</div>

<h5>Chiro Records</h5>
@if (Model.Status.ChiroRecords.Count == 0)
{
  <p class="text-muted">None.</p>
}
else
{
  <table class="table table-striped table-sm mb-4">
    <thead>
      <tr>
        <th class="text-nowrap">ID</th>
        <th class="text-nowrap">Data entered</th>
        <th class="text-nowrap">Recorded</th>
        <th class="text-nowrap">Processed</th>
        <th class="text-nowrap">Delay</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var record in Model.Status.ChiroRecords)
      {
        <tr>
          <td>@record.Id</td>
          <td class="text-nowrap">@record.DataEnteredAt</td>
          <td class="text-nowrap">@record.RecordedAt</td>
          <td class="text-nowrap">
            @if (record.ProcessedAt == null)
            {
              <span class="badge bg-warning text-dark">Pending</span>
            }
            else
            {
              @record.ProcessedAt
            }
          </td>
          <td class="text-nowrap">@record.Delay</td>
        </tr>
      }
    </tbody>
  </table>
}

