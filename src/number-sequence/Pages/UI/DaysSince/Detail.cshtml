@page "/ui/days-since/{id}"
@model number_sequence.Pages.UI.DaysSince.DetailModel
@{
  var label = Model.DaysSince.FriendlyName ?? Model.DaysSince.Id;
  var dayWord = Model.DayCount == 1 ? "day" : "days";
  ViewData["Title"] = $"{Model.DayCount} {dayWord} since {label}";
}

<div class="row justify-content-center mb-4">
  <div class="col-12 col-sm-8 col-md-6 col-lg-4">
    <svg viewBox="0 0 400 400" class="w-100" xmlns="http://www.w3.org/2000/svg">
      <!-- Background -->
      <rect width="100%" height="100%" fill="yellow" />
      <!-- Outer edge stripes -->
      <defs>
        <pattern id="stripes" patternUnits="userSpaceOnUse" width="50" height="20" patternTransform="rotate(45)">
          <rect width="25" height="20" fill="black" />
        </pattern>
        <mask id="innerMask">
          <rect x="0" y="0" width="40" height="400" fill="white" />
          <rect x="0" y="0" width="400" height="40" fill="white" />
          <rect x="360" y="0" width="40" height="400" fill="white" />
          <rect x="0" y="360" width="400" height="40" fill="white" />
        </mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#stripes)" mask="url(#innerMask)" />
      <!-- White rectangle -->
      <rect x="50" y="50" width="300" height="100" fill="white" stroke="black" stroke-width="3" />
      <!-- Days counter -->
      <text x="200" y="130" font-size="80" font-weight="bold" fill="blue" text-anchor="middle">@Model.DayCount</text>
      <!-- Days since text -->
      <text x="200" y="200" font-size="40" font-weight="bold" fill="black" text-anchor="middle">DAY@(Model.DayCount != 1
                ? "S" : "") SINCE</text>
        <!-- Days since descriptive text -->
        @if (Model.DaysSince.ValueLine4 != null)
        {
          @:<text x="200" y="250" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine1</text>
          @:<text x="200" y="280" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine2</text>
          @:<text x="200" y="310" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine3</text>
          @:<text x="200" y="340" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine4</text>
        }
        else if (Model.DaysSince.ValueLine3 != null)
        {
          @:<text x="200" y="260" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine1</text>
          @:<text x="200" y="290" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine2</text>
          @:<text x="200" y="320" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine3</text>
        }
        else if (Model.DaysSince.ValueLine2 != null)
        {
          @:<text x="200" y="270" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine1</text>
          @:<text x="200" y="300" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine2</text>
        }
        else
        {
          @:<text x="200" y="280" font-size="30" fill="black" text-anchor="middle">@Model.DaysSince.ValueLine1</text>
        }
      </svg>
    </div>
  </div>

  <div class="d-flex align-items-center gap-3 mb-3">
    <h5 class="mb-0">Event history</h5>
    @if (User.Identity?.IsAuthenticated == true && Model.DaysSince.AccountName == User.Identity.Name)
    {
      <a href="/ui/days-since/@Model.DaysSince.Id/add-event" class="btn btn-sm btn-primary">Add event</a>
    }
  </div>

  @if (Model.DaysSince.Events?.Any() == true)
  {
    <table class="table table-striped table-sm">
      <thead>
        <tr>
          <th class="text-nowrap">Date</th>
          <th class="text-nowrap text-center">Days ago</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var ev in Model.DaysSince.Events.OrderByDescending(e => e.EventDate))
        {
          var daysAgo = (int)(DateTime.UtcNow - ev.EventDate.ToDateTime(new(), DateTimeKind.Utc)).TotalDays;
          <tr>
            <td class="text-nowrap">@ev.EventDate.ToString("yyyy-MM-dd")</td>
            <td class="text-nowrap text-center">@daysAgo</td>
            <td>@ev.Description</td>
          </tr>
        }
      </tbody>
    </table>
  }
  else
  {
    <p class="text-muted">No events recorded.</p>
  }