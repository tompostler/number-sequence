@page "/ui/ledger/line-defaults"
@model number_sequence.Pages.UI.Ledger.LineDefaults.IndexModel
@{
  ViewData["Title"] = "Line Defaults";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/ui/ledger" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
  <h2 class="mb-0">Line Defaults</h2>
  <a href="/ui/ledger/line-defaults/create" class="btn btn-sm btn-primary">Create</a>
</div>

@if (Model.LineDefaults.Count == 0)
{
  <p class="text-muted">No line defaults yet.</p>
}
else
{
  <table class="table table-striped table-sm w-auto">
    <thead>
      <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Quantity</th>
        <th>Unit</th>
        <th>Price</th>
        <th class="text-nowrap">Created</th>
        <th class="text-nowrap">Modified</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var d in Model.LineDefaults)
      {
        <tr>
          <td><a href="/ui/ledger/line-defaults/@d.Id/edit">@d.Id</a></td>
          <td>@d.Title</td>
          <td>@d.Quantity</td>
          <td>@d.Unit</td>
          <td>@d.Price.ToString("C")</td>
          <td class="text-nowrap">@d.CreatedDate.ToString("yyyy-MM-dd")</td>
          <td class="text-nowrap">@d.ModifiedDate.ToString("yyyy-MM-dd")</td>
        </tr>
      }
    </tbody>
  </table>
}
