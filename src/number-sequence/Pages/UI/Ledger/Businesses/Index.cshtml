@page "/ui/ledger/businesses"
@model number_sequence.Pages.UI.Ledger.Businesses.IndexModel
@{
  ViewData["Title"] = "Businesses";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/ui/ledger" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
  <h2 class="mb-0">Businesses</h2>
  <a href="/ui/ledger/businesses/create" class="btn btn-sm btn-primary">Create</a>
</div>

@if (Model.Businesses.Count == 0)
{
  <p class="text-muted">No businesses yet.</p>
}
else
{
  <table class="table table-striped table-sm w-auto">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Payable Name</th>
        <th>Contact</th>
        <th class="text-nowrap">Created</th>
        <th class="text-nowrap">Modified</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var b in Model.Businesses)
      {
        <tr>
          <td><a href="/ui/ledger/businesses/@b.Id">@b.Id</a></td>
          <td>@b.Name</td>
          <td>@b.PayableName</td>
          <td>@b.Contact</td>
          <td class="text-nowrap">@b.CreatedDate.ToString("yyyy-MM-dd")</td>
          <td class="text-nowrap">@b.ModifiedDate.ToString("yyyy-MM-dd")</td>
        </tr>
      }
    </tbody>
  </table>
}
