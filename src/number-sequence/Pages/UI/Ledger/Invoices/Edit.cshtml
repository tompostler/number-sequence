@page "/ui/ledger/invoices/{id:long}/edit"
@model number_sequence.Pages.UI.Ledger.Invoices.EditModel
@{
  ViewData["Title"] = "Edit Invoice";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/ui/ledger/invoices/@Model.Invoice.Id" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
  <h2 class="mb-0">Edit Invoice</h2>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
  <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="col-12 col-md-8 col-lg-6">
  <form method="post">
    <div class="mb-3">
      <label asp-for="Invoice.Title" class="form-label">Title</label>
      <input asp-for="Invoice.Title" class="form-control" />
      <span asp-validation-for="Invoice.Title" class="text-danger small"></span>
    </div>
    <div class="mb-3">
      <label asp-for="Invoice.Description" class="form-label">Description</label>
      <input asp-for="Invoice.Description" class="form-control" />
      <span asp-validation-for="Invoice.Description" class="text-danger small"></span>
    </div>
    <div class="mb-3">
      <label asp-for="Invoice.DueDate" class="form-label">Due date</label>
      <input asp-for="Invoice.DueDate" class="form-control" type="date" />
      <span asp-validation-for="Invoice.DueDate" class="text-danger small"></span>
    </div>
    <div class="mb-3">
      <label asp-for="BusinessId" class="form-label">Business</label>
      <select asp-for="BusinessId" class="form-select">
        @foreach (var b in Model.Businesses)
        {
          <option value="@b.Id">@b.Name</option>
        }
      </select>
    </div>
    <div class="mb-3">
      <label asp-for="CustomerId" class="form-label">Customer</label>
      <select asp-for="CustomerId" class="form-select">
        @foreach (var c in Model.Customers)
        {
          <option value="@c.Id">@c.Name</option>
        }
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/ui/ledger/invoices/@Model.Invoice.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>
