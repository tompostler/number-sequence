@page "/ui/ledger/customers"
@model number_sequence.Pages.UI.Ledger.Customers.IndexModel
@{
  ViewData["Title"] = "Customers";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/ui/ledger" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
  <h2 class="mb-0">Customers</h2>
  <a href="/ui/ledger/customers/create" class="btn btn-sm btn-primary">Create</a>
</div>

@if (Model.Customers.Count == 0)
{
  <p class="text-muted">No customers yet.</p>
}
else
{
  <table class="table table-striped table-sm w-auto">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Contact</th>
        <th class="text-nowrap">Created</th>
        <th class="text-nowrap">Modified</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var c in Model.Customers)
      {
        <tr>
          <td><a href="/ui/ledger/customers/@c.Id">@c.Id</a></td>
          <td>@c.Name</td>
          <td>@c.Contact</td>
          <td class="text-nowrap">@c.CreatedDate.ToString("yyyy-MM-dd")</td>
          <td class="text-nowrap">@c.ModifiedDate.ToString("yyyy-MM-dd")</td>
        </tr>
      }
    </tbody>
  </table>
}
