@page "/ui/ledger/statements/create"
@model number_sequence.Pages.UI.Ledger.Statements.CreateModel
@{
  ViewData["Title"] = "Create Statement";
}

<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/ui/ledger/statements" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
  <h2 class="mb-0">Create Statement</h2>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
  <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="col-12 col-md-8 col-lg-6">
  <form method="post">
    <div class="mb-3">
      <label asp-for="BusinessId" class="form-label">Business</label>
      <select asp-for="BusinessId" class="form-select">
        <option value="">— select —</option>
        @foreach (var b in Model.Businesses)
        {
          <option value="@b.Id">@b.Name</option>
        }
      </select>
    </div>
    <div class="mb-3">
      <label asp-for="CustomerId" class="form-label">Customer</label>
      <select asp-for="CustomerId" class="form-select">
        <option value="">— select —</option>
        @foreach (var c in Model.Customers)
        {
          <option value="@c.Id">@c.Name</option>
        }
      </select>
    </div>
    <div class="row g-2 mb-3">
      <div class="col">
        <label asp-for="Statement.InvoiceStartDate" class="form-label">Start date</label>
        <input asp-for="Statement.InvoiceStartDate" class="form-control" type="date" />
        <span asp-validation-for="Statement.InvoiceStartDate" class="text-danger small"></span>
      </div>
      <div class="col">
        <label asp-for="Statement.InvoiceEndDate" class="form-label">End date</label>
        <input asp-for="Statement.InvoiceEndDate" class="form-control" type="date" />
        <span asp-validation-for="Statement.InvoiceEndDate" class="text-danger small"></span>
      </div>
    </div>
    <div class="mb-3 form-check">
      <input asp-for="Statement.SearchByDueDate" class="form-check-input" />
      <label asp-for="Statement.SearchByDueDate" class="form-check-label">Search by due date</label>
      <div class="form-text">When checked, matches invoices by due date. Otherwise matches by created date.</div>
    </div>
    <div class="mb-3 form-check">
      <input asp-for="Statement.ReadyForProcessing" class="form-check-input" />
      <label asp-for="Statement.ReadyForProcessing" class="form-check-label">Ready for PDF processing</label>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">Create</button>
      <a href="/ui/ledger/statements" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>
